rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isTaskPoster(task) {
      return signedIn() && task.posterId == request.auth.uid;
    }

    function isAcceptedHelper(task) {
      return signedIn() && task.acceptedBy == request.auth.uid;
    }

    function validTaskCreate() {
      return request.resource.data.posterId == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.description is string &&
        request.resource.data.category is string &&
        request.resource.data.location.address is string &&
        request.resource.data.schedule.date is string &&
        request.resource.data.schedule.time is string &&
        (request.resource.data.paymentOptional == null || request.resource.data.paymentOptional is number) &&
        request.resource.data.paymentStatus == 'pending' &&
        request.resource.data.paymentMethod == null &&
        request.resource.data.status == 'open' &&
        request.resource.data.acceptedBy == null &&
        request.resource.data.acceptedBidId == null;
    }

    function validProfileRole(role) {
      return role in ['user', 'helper'];
    }

    function posterAcceptingBid() {
      return isTaskPoster(resource.data) &&
        resource.data.status == 'open' &&
        request.resource.data.status == 'accepted' &&
        request.resource.data.acceptedBy is string &&
        request.resource.data.acceptedBidId is string;
    }

    function helperRequestingCompletion() {
      return isAcceptedHelper(resource.data) &&
        resource.data.status in ['accepted', 'in_progress'] &&
        request.resource.data.status == 'completion_requested';
    }

    function posterConfirmingCompletion() {
      return isTaskPoster(resource.data) &&
        resource.data.status == 'completion_requested' &&
        request.resource.data.status == 'completed';
    }

    function posterCancellingTask() {
      return isTaskPoster(resource.data) &&
        resource.data.status in ['open', 'accepted', 'in_progress', 'completion_requested'] &&
        request.resource.data.status == 'cancelled';
    }

    function posterConfirmingPayment() {
      return isTaskPoster(resource.data) &&
        resource.data.acceptedBy is string &&
        resource.data.paymentStatus in ['pending', null] &&
        resource.data.status in ['accepted', 'in_progress'] &&
        request.resource.data.paymentStatus == 'paid' &&
        request.resource.data.paymentMethod in ['upi_qr', 'card', 'netbanking'] &&
        request.resource.data.status == 'in_progress';
    }

    function isParticipant(conversationId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    match /profiles/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId && validProfileRole(request.resource.data.role);
      allow update: if signedIn() &&
        (request.auth.uid == userId || isAdmin()) &&
        (!request.resource.data.keys().hasAny(['role']) || validProfileRole(request.resource.data.role));
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if signedIn();
      allow create: if signedIn() && validTaskCreate();
      allow update: if signedIn() &&
        (posterAcceptingBid() || helperRequestingCompletion() || posterConfirmingCompletion() || posterCancellingTask() || posterConfirmingPayment() || isAdmin());
      allow delete: if isAdmin();
    }

    match /bids/{bidId} {
      allow read: if signedIn() &&
        (
          resource.data.helperId == request.auth.uid ||
          resource.data.posterId == request.auth.uid
        );

      allow create: if signedIn() &&
        request.resource.data.helperId == request.auth.uid &&
        request.resource.data.posterId is string &&
        request.resource.data.taskId is string &&
        request.resource.data.amount is number &&
        request.resource.data.status == 'pending';

      allow update: if signedIn() &&
        (
          resource.data.helperId == request.auth.uid ||
          resource.data.posterId == request.auth.uid ||
          isAdmin()
        );

      allow delete: if signedIn() && resource.data.helperId == request.auth.uid;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(conversationId);
        allow create: if isParticipant(conversationId) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string;
        allow update, delete: if false;
      }
    }

    match /ratings/{ratingId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.stars is int &&
        request.resource.data.stars >= 1 && request.resource.data.stars <= 5 &&
        get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.status == 'completed' &&
        (
          (
            get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.posterId == request.auth.uid &&
            get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.acceptedBy == request.resource.data.toUserId
          ) ||
          (
            get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.acceptedBy == request.auth.uid &&
            get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.posterId == request.resource.data.toUserId
          )
        );
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /admin_actions/{actionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
